# ──────────────────────────────────────────────────
# LinkedIn Intelligence Agent — Environment Config
# All services are 100% free tier
# ──────────────────────────────────────────────────

# Database
DATABASE_URL=postgresql+asyncpg://liagent:liagent@localhost:5432/liagent
DATABASE_URL_SYNC=postgresql://liagent:liagent@localhost:5432/liagent

# Redis
REDIS_URL=redis://localhost:6379/0

# AI — Free from https://aistudio.google.com (no credit card)
GEMINI_API_KEY=AIzaSy_your_key_here

# LinkedIn (for ACTIONS only — never for data collection)
LINKEDIN_EMAIL=your@email.com
LINKEDIN_PASSWORD=your_password_here

# Email Finding — all free tiers
APOLLO_API_KEY=your_apollo_key
HUNTER_API_KEY=your_hunter_key
SKRAPP_API_KEY=your_skrapp_key

# Gmail SMTP (free — 500 emails/day)
# Setup: myaccount.google.com → Security → 2-Step Verification → App Passwords
GMAIL_ADDRESS=your@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Auth — Clerk free tier (10,000 MAU)
CLERK_SECRET_KEY=sk_test_your_key
CLERK_PUBLISHABLE_KEY=pk_test_your_key
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_key

# Encryption — generate with: python -c "import secrets; print(secrets.token_hex(32))"
ENCRYPTION_KEY=your_64_char_hex_key_here

# App
APP_NAME=LinkedIn Intelligence Agent
DEBUG=true
TIMEZONE=America/New_York
