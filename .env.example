# =============================================
# RAG Project — Environment Variables
# =============================================
# Copy this file to .env and fill in your values.
# NEVER commit your .env file — it is gitignored.

# ── Google Gemini ─────────────────────────────
# Free at: https://ai.google.dev
GEMINI_API_KEY=your-gemini-api-key-here

# ── Langfuse Observability ────────────────────
# Free at: https://cloud.langfuse.com
# Sign up → Create Project → Copy keys
LANGFUSE_PUBLIC_KEY=pk-lf-xxxxxxxxxxxxxxxxxxxx
LANGFUSE_SECRET_KEY=sk-lf-xxxxxxxxxxxxxxxxxxxx
LANGFUSE_HOST=https://cloud.langfuse.com

# ── Model Config (safe to leave as defaults) ──
EMBEDDING_MODEL=text-embedding-004
LLM_MODEL=gemini-1.5-flash
TOP_K_RETRIEVAL=20
TOP_K_RERANK=5
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# ── Frontend (set this when deploying to Vercel) ─
# NEXT_PUBLIC_API_URL=https://your-render-url.onrender.com
